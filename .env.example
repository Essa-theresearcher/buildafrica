# Supabase — Project Settings → API (https://supabase.com/dashboard)
# IMPORTANT: Replace BOTH lines below. Do not leave the placeholder values.
# URL looks like: https://abcdefghijklmnop.supabase.co
# Anon key starts with: eyJ...
# Use the Project URL (no /rest/v1/) — e.g. https://jnvpthsctgnewlkzckgz.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ_YOUR_ANON_KEY_HERE

# Optional: for running seed script with elevated access
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
